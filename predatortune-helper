#!/bin/bash
# PredatorTune helper -- called via pkexec for privileged operations.

set -euo pipefail

PLATFORM_PROFILE="/sys/firmware/acpi/platform_profile"
VALID_PROFILES="low-power quiet balanced balanced-performance performance"
FAN_SPEED_PATH="/sys/kernel/predatortune/fan_speed"

ACTION="$1"
shift

case "$ACTION" in
    set-profile)
        PROFILE="$1"
        if ! echo "$VALID_PROFILES" | grep -qw "$PROFILE"; then
            echo "Invalid profile: $PROFILE" >&2
            exit 1
        fi
        echo "$PROFILE" > "$PLATFORM_PROFILE"
        ;;
    set-fan-speed)
        # Args: <cpu_pct> <gpu_pct>  (0-100, 0 means auto for that fan)
        CPU_PCT="$1"
        GPU_PCT="$2"
        echo "${CPU_PCT},${GPU_PCT}" > "$FAN_SPEED_PATH"
        ;;
    set-fan-auto)
        echo "0,0" > "$FAN_SPEED_PATH"
        ;;
    *)
        echo "Unknown action: $ACTION" >&2
        exit 1
        ;;
esac
